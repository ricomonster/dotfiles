{
    "custom/arch": {
        "format": "ґ░гЗ",
        "tooltip": true,
        "tooltip-format": "btw"
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "яБк",
            "active": "яЖТ",
            "default": "яДС"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "on-click": "GDK_DISABLE=vulkan pavucontrol"
    },
    "network": {
        "interface": "wlan0",
        "format-icons": [
            "ґ░дп",
            "ґ░дЯ",
            "ґ░дв",
            "ґ░де",
            "ґ░ди"
        ],
        "format-wifi": "{icon} ({signalStrength}%)",
        "format-ethernet": "Ethernet яЮЦ",
        "tooltip-format-wifi": "{icon} {essid}\nтЗг{bandwidthDownBytes}  тЗб{bandwidthUpBytes}",
        "tooltip-format-ethernet": "ґ░АВ  {ifname}\nтЗг{bandwidthDownBytes}  тЗб{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "format-linked": "(No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
        "interval": 5,
        "on-click": "airctl"
    },
    "cpu": {
        "format": "яЛЫ {usage}%",
        "interval": 2,
        "tooltip": true
    },
    "memory": {
        "format": "яГЙ {used:0.2f}/{total:0.0f}GB",
        "interval": 2,
        "on-click": "ghostty -e btop",
        "tooltip": true
    },
    "temperature": {
        "interval": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "critical-threshold": 80,
        "format-critical": "яЛЗ {temperatureC}",
        "format": "яЛЙ {temperatureC}┬░C"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "яЧз  {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%A %B %d %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "custom/power": {
        "format": " ґ░Ре ",
        "tooltip": false,
        "on-click": "wlogout"
    },
    "tray": {
        "icon-size": 15,
        "spacing": 5
    },
    "custom/storage": {
        "format": "яВа {}",
        "format-alt": "{percentage}% яВа",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/modules/storage.sh"
    },
    "custom/music": {
        "format": "{}",
        "return-type": "json",
        "exec": "waybar-module-music --ellipsis --title-width 10"
    }
}
